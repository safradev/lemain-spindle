{
  "name": "lemain-spindle",
  "productName": "Lemain Spindle",
  "version": "0.1.6",
  "private": true,
  "description": "Lemain Spindle — YouTube media extractor",
  "author": "Lemain Labs",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "postinstall": "node scripts/patch-electron-brand.mjs",
    "patch:electron": "node scripts/patch-electron-brand.mjs",
    "dist:win": "electron-builder --win --x64 --publish never"
  },
  "dependencies": {
    "animejs": "^4.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^37.2.3",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.lemain.spindle",
    "productName": "Lemain Spindle",
    "copyright": "Copyright © Lemain Labs",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build-resources/core",
        "to": "core",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build-resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "resources/icon.ico",
      "signtoolOptions": {
        "publisherName": "Lemain Labs",
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      },
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Lemain-Spindle-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lemain Spindle",
      "artifactName": "Lemain-Spindle-${version}-setup.${ext}",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "asar": true,
    "afterPack": "./scripts/ensure-core-resources.cjs"
  }
}
